def pad(horizontal: int = 0, vertical: int = 0):
    return ft.Padding(horizontal, vertical, horizontal, vertical)


def section_title(first: str, accent: str):
    return ft.Row(
        [
            ft.Text(first, size=30, weight=ft.FontWeight.BOLD, color=WHITE, font_family="Georgia"),
            ft.Text(accent, size=30, weight=ft.FontWeight.BOLD, color=PINK, font_family="Georgia"),
        ],
        alignment=ft.MainAxisAlignment.CENTER,
        spacing=6,
        wrap=True,
    )


def soft_shadow():
    return ft.BoxShadow(
        blur_radius=24,
        spread_radius=1,
        color="#00000055",
        offset=ft.Offset(0, 12),
    )


def border_all(width: int, color: str):
    side = ft.BorderSide(width, color)
    return ft.Border(top=side, right=side, bottom=side, left=side)


def pink_button(text: str, icon=None, on_click=None, url: str | None = None):
    return ft.ElevatedButton(
        text,
        icon=icon,
        on_click=on_click,
        url=url,
        bgcolor=PINK,
        color=WHITE,
        style=ft.ButtonStyle(
            shape=ft.RoundedRectangleBorder(radius=5),
            padding=pad(horizontal=16, vertical=13),
        ),
    )


def dark_button(text: str, icon=None, on_click=None, url: str | None = None):
    return ft.OutlinedButton(
        text,
        icon=icon,
        on_click=on_click,
        url=url,
        style=ft.ButtonStyle(
            color=PINK,
            side=ft.BorderSide(1, PINK),
            shape=ft.RoundedRectangleBorder(radius=5),
            padding=pad(horizontal=16, vertical=13),
        ),
    )


def responsive_buttons(*buttons):
    return ft.ResponsiveRow(
        [
            ft.Column(
                [button],
                col={"xs": 12, "sm": 6, "md": 4},
                horizontal_alignment=ft.CrossAxisAlignment.STRETCH,
            )
            for button in buttons
        ],
        spacing=12,
        run_spacing=12,
    )


def page_shell(*controls, horizontal_alignment=ft.CrossAxisAlignment.CENTER):
    return ft.Container(
        padding=pad(horizontal=64, vertical=34),
        content=ft.Column(
            list(controls),
            spacing=22,
            horizontal_alignment=horizontal_alignment,
        ),
    )


